    {
      "name": "Check ID first order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
              "",
              "const res = pm.response.json();",
              "const targetId = pm.request.url.query.get(\"id\");",
              "",
              "pm.test(\"Query param id must exist\", () => {",
              "  pm.expect(targetId, \"Missing query param: id\").to.be.ok;",
              "});",
              "",
              "// --- Deep search helper: find object by key anywhere ---",
              "function findNodeByKey(obj, key) {",
              "  const stack = [{ path: \"$\", value: obj }];",
              "  while (stack.length) {",
              "    const { path, value } = stack.pop();",
              "    if (!value || typeof value !== \"object\") continue;",
              "",
              "    if (Object.prototype.hasOwnProperty.call(value, key)) {",
              "      return { path: `${path}.${key}`, node: value[key] };",
              "    }",
              "",
              "    for (const k of Object.keys(value)) {",
              "      const v = value[k];",
              "      if (v && typeof v === \"object\") {",
              "        stack.push({ path: `${path}.${k}`, value: v });",
              "      }",
              "    }",
              "  }",
              "  return null;",
              "}",
              "",
              "const found = findNodeByKey(res, \"merge_page\");",
              "",
              "pm.test(\"merge_page node found (deep)\", () => {",
              "  pm.expect(found, \"merge_page not found anywhere in response\").to.be.ok;",
              "});",
              "",
              "const mergePage = found?.node;",
              "",
              "// ดึง items จาก path ที่ถูกต้อง: merge_page.result.items",
              "const items = mergePage?.result?.items;",
              "",
              "pm.test(\"merge_page.result.items must be array and not empty\", () => {",
              "  pm.expect(items, \"merge_page.result.items is missing\").to.be.an(\"array\");",
              "  pm.expect(items.length, \"merge_page.result.items is empty\").to.be.above(0);",
              "});",
              "",
              "const firstId = items[0]?.id ?? items[0]?.item_id;",
              "",
              "// ===== EVIDENCE LOG =====",
              "console.log(\"===== MERGE_PAGE FIRST ORDER CHECK =====\");",
              "console.log(\"merge_page found at:\", found?.path);",
              "console.log(\"Target ID (input):\", targetId);",
              "console.log(\"First item ID:\", firstId);",
              "console.log(\"First 10 IDs:\", items.slice(0, 10).map(x => x?.id ?? x?.item_id));",
              "",
              "pm.test(\"Input ID must be at position #1 in merge_page.result.items\", () => {",
              "  pm.expect(",
              "    firstId,",
              "    `❌ Expected first item to be \"${targetId}\" but got \"${firstId}\"`",
              "  ).to.eql(targetId);",
              "});",
              "",
              "if (firstId === targetId) {",
              "  console.log(`✅ PASS: \"${targetId}\" is at position #1`);",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
