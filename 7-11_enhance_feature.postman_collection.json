    {
      "name": "Check ID null random item 001",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// =============================",
              "// BASIC CHECK",
              "// =============================",
              "pm.test(\"HTTP 200\", () => pm.response.to.have.status(200));",
              "const res = pm.response.json();",
              "",
              "// =============================",
              "// helper: deep find merge_page",
              "// =============================",
              "function findNodeByKey(obj, key) {",
              "  const stack = [obj];",
              "  while (stack.length) {",
              "    const v = stack.pop();",
              "    if (!v || typeof v !== \"object\") continue;",
              "    if (Object.prototype.hasOwnProperty.call(v, key)) return v[key];",
              "    Object.values(v).forEach(x => typeof x === \"object\" && stack.push(x));",
              "  }",
              "  return null;",
              "}",
              "",
              "// =============================",
              "// extract items",
              "// =============================",
              "const mergePage = findNodeByKey(res, \"merge_page\");",
              "pm.test(\"merge_page node found\", () => {",
              "  pm.expect(mergePage, \"merge_page not found\").to.be.ok;",
              "});",
              "",
              "const items = mergePage?.result?.items ?? [];",
              "pm.test(\"merge_page.result.items not empty\", () => {",
              "  pm.expect(items.length).to.be.greaterThan(0);",
              "});",
              "",
              "// =============================",
              "// RANDOM SIGNATURE (first 10 ids)",
              "// =============================",
              "const cursor = pm.request.url.query.get(\"cursor\") || \"unknown\";",
              "const signature = items",
              "  .slice(0, 10)",
              "  .map(i => i?.id ?? i?.item_id)",
              "  .filter(Boolean)",
              "  .join(\"|\");",
              "",
              "// =============================",
              "// LOOP CONFIG (เฉพาะ request นี้)",
              "// =============================",
              "const MAX_RUN = 5;",
              "const REQ = pm.info.requestName.replace(/\\s+/g, \"_\");",
              "const ITER_KEY = `iter_${REQ}_cursor_${cursor}`;",
              "const SIGS_KEY = `sigs_${REQ}_cursor_${cursor}`;",
              "",
              "let iter = Number(pm.globals.get(ITER_KEY) || 1);",
              "const sigs = JSON.parse(pm.globals.get(SIGS_KEY) || \"[]\");",
              "",
              "// เก็บ signature รอบนี้",
              "sigs.push(signature);",
              "pm.globals.set(SIGS_KEY, JSON.stringify(sigs));",
              "",
              "// =============================",
              "// LOG",
              "// =============================",
              "console.log(\"===== MERGE_PAGE RANDOM CHECK =====\");",
              "console.log(\"Request:\", pm.info.requestName);",
              "console.log(\"Cursor:\", cursor);",
              "console.log(`Run ${iter}/${MAX_RUN}`);",
              "console.log(\"Signature:\", signature);",
              "",
              "// sanity per-run",
              "pm.test(`[Random] captured signature ${iter}/${MAX_RUN}`, () => {",
              "  pm.expect(signature).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "// =============================",
              "// LOOP CONTROL (สำคัญ)",
              "// =============================",
              "if (iter < MAX_RUN) {",
              "  pm.globals.set(ITER_KEY, String(iter + 1));",
              "  postman.setNextRequest(pm.info.requestName); // 🔁 วน request เดิม",
              "} else {",
              "  // final assertion: ต้องแตกต่างอย่างน้อย 1 ครั้ง",
              "  pm.test(`merge_page should be random (vary at least once) cursor=${cursor}`, () => {",
              "    const unique = new Set(sigs);",
              "    pm.expect(",
              "      unique.size,",
              "      `❌ deterministic order: all ${MAX_RUN} runs same`",
              "    ).to.be.greaterThan(1);",
              "  });",
              "",
              "  // cleanup",
              "  pm.globals.unset(ITER_KEY);",
              "  pm.globals.unset(SIGS_KEY);",
              "",
              "  postman.setNextRequest(null); // ➡️ ไป request ถัดไป",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
