    {
      "name": "Check not in seen item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "/**",
              " * Check that target id is NOT in get_seen_item_redis",
              " * Node shape (your real response):",
              " * - get_seen_item_redis.result.ids: [ ... ]",
              " * - get_seen_item_redis.result.items: [{id}, ...]",
              " */",
              "",
              "pm.test(\"Response status is 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "",
              "// =============================",
              "// HELPERS",
              "// =============================",
              "function deepFindNode(obj, nodeName) {",
              "  if (!obj || typeof obj !== \"object\") return null;",
              "  if (Object.prototype.hasOwnProperty.call(obj, nodeName)) return obj[nodeName];",
              "  for (const k of Object.keys(obj)) {",
              "    const found = deepFindNode(obj[k], nodeName);",
              "    if (found) return found;",
              "  }",
              "  return null;",
              "}",
              "",
              "function uniq(arr) {",
              "  return [...new Set((arr || []).filter(Boolean))];",
              "}",
              "",
              "function getTargetIdFromRequest() {",
              "  const q = pm.request.url.query;",
              "  // prefer id, but fallback to common keys",
              "  const preferred = q.get(\"id\");",
              "  if (preferred) return preferred;",
              "",
              "  const candidates = [\"itemId\", \"contentId\", \"targetId\", \"videoId\", \"pid\"];",
              "  for (const key of candidates) {",
              "    const v = q.get(key);",
              "    if (v) return v;",
              "  }",
              "",
              "  const all = q.all();",
              "  if (Array.isArray(all) && all.length > 0) return all[0]?.value;",
              "",
              "  return null;",
              "}",
              "",
              "function extractSeenIds(seenNode) {",
              "  if (!seenNode || typeof seenNode !== \"object\") return [];",
              "",
              "  // 1) MAIN (your node): result.ids",
              "  const r1 = seenNode?.result?.ids;",
              "  if (Array.isArray(r1)) return uniq(r1);",
              "",
              "  // 2) fallback: result.items[].id",
              "  const r2 = seenNode?.result?.items;",
              "  if (Array.isArray(r2)) return uniq(r2.map(x => x?.id));",
              "",
              "  // 3) fallback: main_function.args.default_response.ids",
              "  const r3 = seenNode?.main_function?.args?.default_response?.ids;",
              "  if (Array.isArray(r3)) return uniq(r3);",
              "",
              "  // 4) fallback: main_function.args.default_response.items[].id",
              "  const r4 = seenNode?.main_function?.args?.default_response?.items;",
              "  if (Array.isArray(r4)) return uniq(r4.map(x => x?.id));",
              "",
              "  return [];",
              "}",
              "",
              "// =============================",
              "// 1) target id",
              "// =============================",
              "const targetId = getTargetIdFromRequest();",
              "",
              "pm.test(\"Target id exists in request\", () => {",
              "  pm.expect(targetId, \"Missing query param: id (or itemId/contentId/targetId/...)\").to.be.ok;",
              "});",
              "",
              "// =============================",
              "// 2) find seen node",
              "// =============================",
              "const SEEN_NODE_NAME = \"get_seen_item_redis\";",
              "",
              "// try direct first, then deep search",
              "const seenNode = res?.[SEEN_NODE_NAME] ?? deepFindNode(res, SEEN_NODE_NAME);",
              "",
              "pm.test(`${SEEN_NODE_NAME} node exists`, () => {",
              "  pm.expect(seenNode, `${SEEN_NODE_NAME} node not found`).to.be.ok;",
              "});",
              "",
              "// =============================",
              "// 3) extract ids",
              "// =============================",
              "const seenIds = extractSeenIds(seenNode);",
              "",
              "pm.test(\"seenIds is array\", () => {",
              "  pm.expect(seenIds).to.be.an(\"array\");",
              "});",
              "",
              "// =============================",
              "// 4) check",
              "// =============================",
              "const inSeen = seenIds.includes(targetId);",
              "",
              "// LOG หลักฐาน",
              "console.log(\"===== SEEN ITEM CHECK =====\");",
              "console.log(\"Target ID:\", targetId);",
              "console.log(\"Seen IDs count:\", seenIds.length);",
              "console.log(\"Is target in seenIds:\", inSeen);",
              "console.log(\"Seen IDs sample (first 50):\", JSON.stringify(seenIds.slice(0, 50), null, 2));",
              "",
              "// เก็บ evidence สำหรับเอาไป push เข้า Xray ต่อ",
              "pm.environment.set(\"seen_item_evidence\", JSON.stringify({",
              "  node: SEEN_NODE_NAME,",
              "  targetId,",
              "  seenIdsCount: seenIds.length,",
              "  isTargetInSeenIds: inSeen,",
              "  seenIdsSample: seenIds.slice(0, 50)",
              "}, null, 2));",
              "",
              "// Assertion",
              "pm.test(\"Target ID should NOT exist in get_seen_item_redis.result.ids\", () => {",
              "  pm.expect(",
              "    inSeen,",
              "    `❌ Found targetId=${targetId} in seenIds (count=${seenIds.length})`",
              "  ).to.eql(false);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
