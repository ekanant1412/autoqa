  "item": [
    {
      "name": "http://poc-ai-universal-platform.preprod-gcp-ai-bn.int-ai-platform.gcp.dmp.true.th/api/v1/sfv-p4",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ===== CHECK SELECTION LOGIC =====",
              "",
              "const response = pm.response.json();",
              "",
              "// ดึง nodes จาก response",
              "const diversify = response.data.results.diversify_items?.result;",
              "const candidates = response.data.results.generate_items_from_candidates?.result;",
              "",
              "// ===== 1. SIZE CHECK =====",
              "pm.test(\"diversify_items: item_size = 100\", () => {",
              "    pm.expect(diversify).to.not.be.undefined;",
              "    pm.expect(diversify.item_size).to.eql(100);",
              "});",
              "",
              "pm.test(\"generate_items_from_candidates: item_size = 100\", () => {",
              "    pm.expect(candidates).to.not.be.undefined;",
              "    pm.expect(candidates.item_size).to.eql(100);",
              "});",
              "",
              "// ===== 4. SEEN ITEMS CHECK — get_redis_seen_items ต้องว่างเปล่า =====",
              "const seenItems = response.data.results.get_redis_seen_items?.result;",
              "",
              "pm.test(\"get_redis_seen_items: items should be empty\", () => {",
              "    pm.expect(seenItems).to.not.be.undefined;",
              "    pm.expect(seenItems.items).to.be.an('array').that.is.empty;",
              "    pm.expect(seenItems.ids).to.be.an('array').that.is.empty;",
              "    pm.expect(seenItems.item_size).to.eql(0);",
              "});",
              "",
              "// ===== 2. COVERAGE CHECK — ทุก item ใน diversify ต้องมีใน candidates =====",
              "if (diversify && candidates) {",
              "    const divIds = new Set(diversify.ids);",
              "    const candIds = new Set(candidates.ids);",
              "",
              "    const notInCandidates = [...divIds].filter(id => !candIds.has(id));",
              "",
              "    pm.test(`Coverage: all diversify items exist in candidates (missing: ${notInCandidates.length})`, () => {",
              "        pm.expect(notInCandidates).to.have.lengthOf(0,",
              "            `Missing IDs: ${notInCandidates.join(\", \")}`",
              "        );",
              "    });",
              "",
              "    // ===== 3. RANDOMNESS CHECK — order ต้องไม่เหมือนเดิม =====",
              "    const divList = diversify.ids;",
              "    const candList = candidates.ids;",
              "",
              "    const candPosMap = {};",
              "    candList.forEach((id, i) => candPosMap[id] = i);",
              "",
              "    let samePositionCount = 0;",
              "    let totalShift = 0;",
              "    let maxShift = 0;",
              "",
              "    divList.forEach((id, divPos) => {",
              "        if (candPosMap[id] !== undefined) {",
              "            const shift = Math.abs(divPos - candPosMap[id]);",
              "            if (shift === 0) samePositionCount++;",
              "            totalShift += shift;",
              "            if (shift > maxShift) maxShift = shift;",
              "        }",
              "    });",
              "",
              "    const avgShift = (totalShift / divList.length).toFixed(1);",
              "",
              "    pm.test(`Randomness: items are shuffled (avg shift: ${avgShift}, max: ${maxShift})`, () => {",
              "        pm.expect(samePositionCount).to.be.below(",
              "            divList.length * 0.1,",
              "            `Too many items at same position: ${samePositionCount}`",
              "        );",
              "    });",
              "",
              "    pm.test(\"Randomness: order is not identical to candidates\", () => {",
              "        const isSameOrder = divList.every((id, i) => id === candList[i]);",
              "        pm.expect(isSameOrder).to.be.false;",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
