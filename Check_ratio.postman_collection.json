    {
      "name": "check_ratio",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ===== RATIO CHECK FROM calculate_candidates_with_ratio =====",
              "// Validate final candidates_items count against ratio parameters.",
              "// If final count < expected, check source candidate pool node.",
              "// If source pool is also insufficient, do NOT fail; log NOTE instead.",
              "",
              "// --------------------------------------------",
              "// Mapping",
              "// --------------------------------------------",
              "const ratioNodeMap = [",
              "    { param: \"node_latest_sfv_ratio\",        finalNode: \"candidate_latest_sfv\",        sourceNode: \"candidate_latest_sfv\" },",
              "    { param: \"node_latest_ugc_sfv_ratio\",    finalNode: \"candidate_latest_ugc_sfv\",    sourceNode: \"candidate_latest_ugc_sfv\" },",
              "    { param: \"node_latest_sfv_series_ratio\", finalNode: \"candidate_latest_sfv_series\", sourceNode: \"candidate_latest_sfv_series\" },",
              "    { param: \"node_tophit_sfv_ratio\",        finalNode: \"candidate_tophit_sfv\",        sourceNode: \"candidate_tophit_sfv\" },",
              "    { param: \"node_tophit_ugc_sfv_ratio\",    finalNode: \"candidate_tophit_ugc_sfv\",    sourceNode: \"candidate_tophit_ugc_sfv\" },",
              "    { param: \"node_tophit_sfv_series_ratio\", finalNode: \"candidate_tophit_sfv_series\", sourceNode: \"candidate_tophit_sfv_series\" },",
              "];",
              "",
              "// --------------------------------------------",
              "// Helpers",
              "// --------------------------------------------",
              "function safeJsonParseResponse() {",
              "    try {",
              "        return pm.response.json();",
              "    } catch (e) {",
              "        console.error(\"[ERROR] Response is not valid JSON\", e);",
              "        return null;",
              "    }",
              "}",
              "",
              "function getNode(results, nodeName) {",
              "    return results?.[nodeName];",
              "}",
              "",
              "function getArrayLength(value) {",
              "    return Array.isArray(value) ? value.length : null;",
              "}",
              "",
              "function extractPoolItems(nodeObj) {",
              "    if (!nodeObj) return null;",
              "",
              "    if (Array.isArray(nodeObj?.result)) return nodeObj.result;",
              "    if (Array.isArray(nodeObj?.result?.items)) return nodeObj.result.items;",
              "    if (Array.isArray(nodeObj?.result?.contents)) return nodeObj.result.contents;",
              "    if (Array.isArray(nodeObj?.result?.data)) return nodeObj.result.data;",
              "",
              "    const result = nodeObj?.result;",
              "    if (result && typeof result === \"object\") {",
              "        for (const key of Object.keys(result)) {",
              "            if (Array.isArray(result[key])) {",
              "                return result[key];",
              "            }",
              "        }",
              "    }",
              "",
              "    return null;",
              "}",
              "",
              "// --------------------------------------------",
              "// Read response",
              "// --------------------------------------------",
              "const responseJson = safeJsonParseResponse();",
              "",
              "pm.test(\"Response should be valid JSON\", function () {",
              "    pm.expect(responseJson, \"Response JSON is invalid\").to.not.be.null;",
              "});",
              "",
              "if (!responseJson) return;",
              "",
              "const results = responseJson?.data?.results || {};",
              "const calcNode = results?.calculate_candidates_with_ratio;",
              "const calcParams = calcNode?.parameters || {};",
              "const calcResult = calcNode?.result || {};",
              "const finalCandidatesItems = calcResult?.candidates_items || {};",
              "const finalCandidatesCount = calcResult?.candidates_items_count || {};",
              "const finalTotalItemSize = calcResult?.item_size;",
              "",
              "const shortageNotes = [];",
              "",
              "console.log(\"========== RATIO CHECK START ==========\");",
              "",
              "// --------------------------------------------",
              "// Validate per node",
              "// --------------------------------------------",
              "ratioNodeMap.forEach(({ param, finalNode, sourceNode }) => {",
              "",
              "    const expectedCount = calcParams?.[param];",
              "    const finalItems = finalCandidatesItems?.[finalNode];",
              "    const finalItemsLen = getArrayLength(finalItems);",
              "",
              "    const countKey = `${finalNode}_count`;",
              "    const finalCountFromCountMap = finalCandidatesCount?.[countKey];",
              "",
              "    console.log(\"--------------------------------------------------\");",
              "    console.log(\"Node:\", finalNode);",
              "    console.log(\"Expected:\", expectedCount);",
              "    console.log(\"Final:\", finalItemsLen);",
              "",
              "    pm.test(`[RATIO] ${finalNode}: ratio parameter exists`, function () {",
              "        pm.expect(expectedCount).to.not.be.undefined;",
              "    });",
              "",
              "    pm.test(`[STRUCTURE] ${finalNode}: candidates_items exists`, function () {",
              "        pm.expect(Array.isArray(finalItems)).to.be.true;",
              "    });",
              "",
              "    pm.test(`[COUNT MAP] ${finalNode}: count map matches array`, function () {",
              "        pm.expect(finalCountFromCountMap).to.eql(finalItemsLen);",
              "    });",
              "",
              "    if (finalItemsLen === expectedCount) {",
              "        console.log(`[PASS] ${finalNode} count OK`);",
              "        return;",
              "    }",
              "",
              "    console.warn(`[WARN] ${finalNode} count mismatch expected=${expectedCount} actual=${finalItemsLen}`);",
              "",
              "    const sourceNodeObj = getNode(results, sourceNode);",
              "    const sourceItems = extractPoolItems(sourceNodeObj);",
              "    const sourceItemsLen = getArrayLength(sourceItems);",
              "",
              "    console.log(\"Source pool:\", sourceItemsLen);",
              "",
              "    if (sourceItemsLen < expectedCount) {",
              "",
              "        shortageNotes.push({",
              "            node: finalNode,",
              "            expected: expectedCount,",
              "            source: sourceItemsLen,",
              "            final: finalItemsLen",
              "        });",
              "",
              "        console.warn(`[NOTE] ${finalNode} source pool insufficient (${sourceItemsLen}/${expectedCount})`);",
              "        return;",
              "    }",
              "",
              "    pm.test(`[FAIL] ${finalNode}: source pool has enough items but output too small`, function () {",
              "        pm.expect(finalItemsLen).to.eql(expectedCount);",
              "    });",
              "",
              "});",
              "",
              "// --------------------------------------------",
              "// TOTAL (log only - no fail)",
              "// --------------------------------------------",
              "const expectedTotalFromRatios = ratioNodeMap.reduce((sum, { param }) => {",
              "    const v = calcParams?.[param];",
              "    return sum + (Number.isInteger(v) ? v : 0);",
              "}, 0);",
              "",
              "const totalGap = expectedTotalFromRatios - finalTotalItemSize;",
              "",
              "console.log(\"--------------------------------------------------\");",
              "console.log(\"Expected Total:\", expectedTotalFromRatios);",
              "console.log(\"Final Total:\", finalTotalItemSize);",
              "console.log(\"Gap:\", totalGap);",
              "",
              "if (totalGap > 0) {",
              "    console.warn(`[NOTE] Total mismatch accepted expected=${expectedTotalFromRatios} actual=${finalTotalItemSize}`);",
              "}",
              "",
              "console.log(\"Shortage Nodes:\", shortageNotes);",
              "console.log(\"========== RATIO CHECK END ==========\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
