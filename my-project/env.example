# ── Xray Cloud API ────────────────────────────────────────────────────────────
# ไปที่ Jira → Xray → Settings → API Keys → สร้าง key ใหม่
XRAY_CLIENT_ID=your_xray_client_id_here
XRAY_CLIENT_SECRET=your_xray_client_secret_here

# ── Jira Project ──────────────────────────────────────────────────────────────
JIRA_PROJECT_KEY=PROJ          # เช่น DMP, QA, TEST
JIRA_BASE_URL=https://yourcompany.atlassian.net

# ── Jira API Token ────────────────────────────────────────────────────────────
# ไปที่ https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Optional: ผูก Test Execution กับ Test Plan ───────────────────────────────
XRAY_TEST_PLAN_KEY=PROJ-123    # ถ้าไม่มีให้ลบบรรทัดนี้ออก
